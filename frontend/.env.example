# Local development (default, already set in .env):
# VITE_API_URL=http://127.0.0.1:5000

# Production (e.g. on Vercel): set this in your hosting provider's
# environment variable settings to your DEPLOYED backend's public URL —
# not localhost, since visitors' browsers can't reach your machine.
# Example, if the backend is deployed on Render:
# VITE_API_URL=https://your-backend-name.onrender.com
